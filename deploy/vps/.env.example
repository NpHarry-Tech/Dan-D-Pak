APP_DOMAIN=app.example.com
NODE_ENV=production
PORT=3000
APP_URL=https://app.example.com
API_BASE_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com

DEPLOYMENT_TARGET=vps

# Current app runtime. Change to postgres only after migration is implemented and verified.
DATABASE_PROVIDER=sqlite
SQLITE_PATH=/app/server-data/store.db

# Target PostgreSQL service for migration phase.
DATABASE_URL=postgres://dandpak:change-me@postgres:5432/dandpak
POSTGRES_DB=dandpak
POSTGRES_USER=dandpak
POSTGRES_PASSWORD=change-me

REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=local
STORAGE_PATH=/app/storage

JWT_SECRET=change-me
SESSION_SECRET=change-me
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=14

# Temporary Supabase values, if used during demo migration only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
