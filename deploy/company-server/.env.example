# ============================================================
# Dan D Pak POS/ERP — Cấu hình triển khai máy chủ công ty
# ============================================================
# HƯỚNG DẪN:
#   1. Sao chép file này thành .env  (cp .env.example .env)
#   2. Thay thế TẤT CẢ giá trị có chú thích [BẮT BUỘC THAY]
#   3. Không commit file .env lên Git
# ============================================================

# --- Tên miền / địa chỉ IP máy chủ [BẮT BUỘC THAY] ---
# Ví dụ: APP_DOMAIN=192.168.1.100  (IP tĩnh trong mạng LAN)
#        APP_DOMAIN=pos.cty-abc.local  (hostname nội bộ)
APP_DOMAIN=192.168.1.100
APP_URL=http://192.168.1.100
API_BASE_URL=http://192.168.1.100
CORS_ORIGIN=http://192.168.1.100

# --- Môi trường ---
NODE_ENV=production
PORT=3000
DEPLOYMENT_TARGET=company-server

# --- Cơ sở dữ liệu SQLite (chính) ---
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///app/server-data/store.db

# --- Cơ sở dữ liệu PostgreSQL (sidecar — dùng cho backup tự động) ---
POSTGRES_DB=dandpak
POSTGRES_USER=dandpak
# [BẮT BUỘC THAY] Mật khẩu mạnh, không để mặc định
POSTGRES_PASSWORD=Thay_Mat_Khau_Manh_Tai_Day!

# --- Realtime & Storage ---
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=local
STORAGE_PATH=/app/storage

# --- Bảo mật [BẮT BUỘC THAY] ---
# Tạo bằng lệnh: openssl rand -hex 32
JWT_SECRET=thay-bang-chuoi-ngau-nhien-64-ky-tu-hex
SESSION_SECRET=thay-bang-chuoi-ngau-nhien-64-ky-tu-khac

# --- Ghi log ---
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=30

# --- Seed cấu hình lần đầu (tùy chọn) ---
# Nếu để trống: hệ thống tự tạo dữ liệu demo khi DB còn trống.
# Để bỏ demo seed, bỏ comment dòng dưới:
# DISABLE_DEMO_SEED=true
CONFIG_SEED_URL=
