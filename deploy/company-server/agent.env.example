# Cách dùng: copy file này thành .env.agent trong thư mục server/
#   cp server/.env.agent.example server/.env.agent
# rồi sửa các giá trị bên dưới và chạy:  node server/agent.js
# ============================================================

# Địa chỉ server trung tâm (VPS). KHÔNG kèm dấu / ở cuối.
CENTRAL_URL=http://42.96.18.70:3000

# Tài khoản agent đăng nhập (nên dùng tài khoản kho/thu ngân của chi nhánh).
AGENT_USERNAME=warehouse
AGENT_PIN=5555

# Chi nhánh mà máy này phục vụ.
BRANCH_ID=br1

# (Tùy chọn) nhịp hỏi phiếu in & báo máy in — mặc định đủ dùng.
# AGENT_POLL_MS=1500
# AGENT_PRINTERS_MS=20000
# AGENT_MAX_ATTEMPTS=3
# AGENT_COOLDOWN_MS=20000
