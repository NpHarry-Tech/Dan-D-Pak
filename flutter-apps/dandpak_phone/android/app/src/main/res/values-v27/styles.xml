<?xml version="1.0" encoding="utf-8"?>
<!-- Android 8.1+ (API 27): cho phép vẽ TRÀN VÀO vùng khuyết (tai thỏ/notch)
     thay vì để hệ điều hành chèn dải đen — Flutter nhận inset qua MediaQuery
     và SafeArea ở builder gốc tự né phần khuyết trên mọi kiểu màn hình. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
