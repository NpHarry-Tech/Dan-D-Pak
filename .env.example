NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DEPLOYMENT_TARGET=local
DATABASE_PROVIDER=sqlite
SQLITE_PATH=runtime/server-data/store.db
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=local
STORAGE_PATH=storage

# Temporary demo provider values. Keep service-role keys backend-only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Final VPS/PostgreSQL target values.
DATABASE_URL=postgres://dandpak:change-me@postgres:5432/dandpak
POSTGRES_DB=dandpak
POSTGRES_USER=dandpak
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me
SESSION_SECRET=change-me
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=14

# Haravan connector. Keep token/secret backend-only.
HARAVAN_ENABLED=false
HARAVAN_SHOP_DOMAIN=your-shop.myharavan.com
HARAVAN_ACCESS_TOKEN=
HARAVAN_WEBHOOK_SECRET=
HARAVAN_CLIENT_ID=
HARAVAN_CLIENT_SECRET=
HARAVAN_WEBHOOK_VERIFY_TOKEN=
HARAVAN_SCOPES=openid org profile userinfo grant_service wh_api com.read_orders com.write_orders com.read_products com.write_products com.read_customers com.write_customers com.read_inventories com.write_inventories
HARAVAN_LOCATION_ID=
HARAVAN_API_BASE_URL=https://apis.haravan.com
HARAVAN_DEFAULT_BRANCH_ID=ONLINE
