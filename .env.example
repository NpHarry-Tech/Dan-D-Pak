NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DEPLOYMENT_TARGET=local
DATABASE_PROVIDER=sqlite
SQLITE_PATH=server/store.db
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=local
STORAGE_PATH=storage

# Temporary demo provider values. Keep service-role keys backend-only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Final VPS/PostgreSQL target values.
DATABASE_URL=postgres://dandpak:change-me@postgres:5432/dandpak
POSTGRES_DB=dandpak
POSTGRES_USER=dandpak
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me
SESSION_SECRET=change-me
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=14

# Auto-backup path: config (users, settings, menu…) is auto-saved here after every change
# and auto-restored on startup when the DB is empty (e.g. after a Render redeploy).
# Set to a path on a persistent volume so data survives redeploys.
# Example for Render persistent disk: CONFIG_BACKUP_PATH=/app/server-data/config-backup.json
CONFIG_BACKUP_PATH=
