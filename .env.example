NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DEPLOYMENT_TARGET=local
DATABASE_PROVIDER=sqlite
SQLITE_PATH=server/store.db
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=local
STORAGE_PATH=storage
APP_DATA_DIR=
BACKUP_PATH=
PERMANENT_STORAGE_PATH=
ENTERPRISE_STORAGE_PATH=
UPLOADS_PATH=
SYNC_REPLICA_PATH=
DEVICE_ID=
CENTRAL_SYNC_URL=
CENTRAL_SYNC_TOKEN=

# Temporary demo provider values. Keep service-role keys backend-only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Final VPS/PostgreSQL target values.
DATABASE_URL=postgres://dandpak:change-me@postgres:5432/dandpak
POSTGRES_DB=dandpak
POSTGRES_USER=dandpak
POSTGRES_PASSWORD=change-me

# Secrets — ĐẶT TRƯỚC KHI CHẠY PRODUCTION. Sinh chuỗi ngẫu nhiên:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me
SESSION_SECRET=change-me
DANDPAK_ADMIN_RESET_PIN=
# Khóa mã hóa chi tiết nhật ký hoạt động (audit log) khi nén/lưu trữ bản ghi > 90 ngày.
# Nếu để trống, hệ thống dùng SESSION_SECRET, rồi tới một khóa mặc định CÔNG KHAI trong source
# (mã hóa coi như vô nghĩa). ĐẶT NGAY TỪ ĐẦU và KHÔNG đổi về sau — đổi khóa sẽ làm
# các log đã mã hóa bằng khóa cũ không giải mã lại được.
AUDIT_LOG_KEY=
# CORS: danh sách origin tin cậy, phân tách bằng dấu phẩy. BẮT BUỘC ở production
# (để trống ở production => chặn mọi cross-origin; '*' => cho tất cả, chỉ dùng khi thật cần).
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=14
